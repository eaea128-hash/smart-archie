# ============================================================
#  Smart Archie — Environment Variables Template
#  Copy this file to .env and fill in your actual values.
#  NEVER commit .env to version control.
#
#  Netlify 設定位置：
#    Site Settings → Environment Variables → Add variable
# ============================================================

# ── Anthropic Claude API ────────────────────────────────────
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_WITH_YOUR_KEY

# Optional: Override default Claude model (default: claude-opus-4-6)
CLAUDE_MODEL=claude-opus-4-6

# Optional: Max tokens for analysis responses (default: 8000)
CLAUDE_MAX_TOKENS=8000

# ── Supabase ────────────────────────────────────────────────
# Get these from: https://app.supabase.com → Project → Settings → API
#
# Public anon key (safe to expose in frontend)
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.REPLACE_WITH_ANON_KEY

# Service role key (KEEP SECRET — only used in Netlify Functions)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.REPLACE_WITH_SERVICE_ROLE_KEY

# ── Error Monitoring: Sentry ─────────────────────────────────
# Get your DSN at: https://sentry.io → Project → Settings → Client Keys
# Leave blank to disable Sentry
SENTRY_DSN=https://REPLACE@o123456.ingest.sentry.io/REPLACE

# ── Usage Analytics: Mixpanel ────────────────────────────────
# Get your token at: https://mixpanel.com → Project → Settings
# Leave blank to disable Mixpanel
MIXPANEL_TOKEN=REPLACE_WITH_MIXPANEL_TOKEN

# ── App Environment ──────────────────────────────────────────
NODE_ENV=development

# Rate limiting (requests per hour per session — 0 to disable)
RATE_LIMIT_RPH=20

# CORS — comma-separated allowed origins (blank = allow all in dev)
ALLOWED_ORIGINS=

# Netlify site URL (auto-set in Netlify environment)
URL=http://localhost:8888
