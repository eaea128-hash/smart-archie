# ============================================================
#  Smart Archie — Environment Variables Template
#  Copy this file to .env and fill in your actual values.
#  NEVER commit .env to version control.
# ============================================================

# Anthropic Claude API
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_WITH_YOUR_KEY

# App Environment (development | staging | production)
NODE_ENV=development

# Optional: Override default Claude model
# Default: claude-opus-4-6
CLAUDE_MODEL=claude-opus-4-6

# Optional: Max tokens for analysis responses (default: 8000)
CLAUDE_MAX_TOKENS=8000

# Rate limiting (requests per hour per session — set to 0 to disable)
RATE_LIMIT_RPH=20

# CORS — comma-separated allowed origins (leave blank to allow all in dev)
# Example: https://smart-archie.netlify.app,https://smartarchie.ai
ALLOWED_ORIGINS=

# Netlify site URL (set automatically in Netlify environment)
URL=http://localhost:8888
