{
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add *)",
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(git pull*)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(node *)",
      "Bash(npm install*)",
      "Bash(npm run*)",
      "Bash(mkdir *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(grep *)",
      "Bash(echo *)",
      "Read(*)",
      "Write(*.html)",
      "Write(*.css)",
      "Write(*.js)",
      "Write(*.json)",
      "Write(*.md)",
      "Write(*.toml)",
      "Write(*.txt)",
      "Write(*.xml)",
      "Write(*.svg)",
      "Write(*.sql)",
      "Write(*.sh)",
      "Edit(*)",
      "Glob(*)",
      "Grep(*)",
      "WebFetch(*)",
      "WebSearch(*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(del /f *)",
      "Bash(format *)",
      "Bash(DROP TABLE*)",
      "Bash(* --no-verify)",
      "Bash(git push --force*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash(git commit*)",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-commit.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit(supabase-schema.sql)",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-schema-edit.sh"
          }
        ]
      },
      {
        "matcher": "Write(supabase-schema.sql)",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-schema-edit.sh"
          }
        ]
      },
      {
        "matcher": "Edit(functions/api/*.js)",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-function-edit.sh"
          }
        ]
      },
      {
        "matcher": "Write(functions/api/*.js)",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-function-edit.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c \"\nimport sys, json\ntry:\n    data = json.load(sys.stdin)\n    f = data.get('tool_input', {}).get('file_path', '')\n    if f.endswith(('.html', '.js')):\n        print(json.dumps({'hookSpecificOutput':{'hookEventName':'PostToolUse','additionalContext':'[testing-guard required] You modified ' + f + ' — run /testing-guard before reporting this task complete.'}}))\n    else:\n        print('{}')\nexcept:\n    print('{}')\n\"",
            "statusMessage": "Checking if testing-guard required…"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"systemMessage\":\"\\u26a0\\ufe0f If you edited .html or .js files this turn, confirm /testing-guard has been run before this response ends.\"}'"
          }
        ]
      }
    ]
  }
}
