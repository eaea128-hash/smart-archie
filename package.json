{
  "name": "smart-archie",
  "version": "1.0.0",
  "description": "AI Cloud Advisory Platform — Services as Software",
  "private": true,
  "scripts": {
    "dev": "netlify dev",
    "build": "echo 'Static site — no build step required'",
    "lint": "eslint netlify/functions --ext .js",
    "test": "jest --passWithNoTests",
    "format": "prettier --write '**/*.{js,json,css,html,md}' --ignore-path .gitignore"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "netlify-cli": "^17.0.0",
    "prettier": "^3.3.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/__tests__/**/*.js", "**/*.test.js"]
  },
  "eslintConfig": {
    "env": {
      "node": true,
      "es2022": true
    },
    "parserOptions": {
      "ecmaVersion": 2022,
      "sourceType": "module"
    },
    "rules": {
      "no-console": "off",
      "no-unused-vars": "warn"
    }
  }
}
