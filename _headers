/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://fonts.googleapis.com https://browser.sentry-cdn.com https://cdn.mxpnl.com https://unpkg.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://fonts.gstatic.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://*.supabase.co https://api.anthropic.com https://sentry.io https://*.sentry.io https://browser.sentry-cdn.com https://api.mixpanel.com https://api.openai.com https://api.resend.com https://cdn.jsdelivr.net https://formspree.io;
  # Force revalidation so bare URLs (e.g. /analyze) never serve a stale build.
  # ETag-based 304s keep this cheap. Long-lived static assets override below.
  Cache-Control: no-cache

# Immutable static assets can be cached aggressively (override the no-cache above)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

/favicon.svg
  Cache-Control: public, max-age=604800

/api/*
  Access-Control-Allow-Origin: *
  Access-Control-Allow-Methods: GET, POST, OPTIONS, DELETE
  Access-Control-Allow-Headers: Content-Type, Authorization
